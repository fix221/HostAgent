#!/bin/bash
# ============================================================================
# OpenIDCS-Client 管理脚本
# 用法: openidcs {start|stop|restart|status|update|uninstall|log|info|help}
# ============================================================================

# ======================== 配置 ========================
INSTALL_DIR="/opt/openidcs"
SERVICE_NAME="openidcs"
BIN_LINK="/usr/local/bin/openidcs"
DATA_DIR="${INSTALL_DIR}/DataSaving"
DOWNLOAD_URL="https://github.com/OpenIDCSTeam/HostAgent/releases/download/alpha/OpenIDCS-Client-cxfreeze-Linux.tar.gz"
INSTALL_SCRIPT_URL="https://raw.githubusercontent.com/OpenIDCSTeam/HostAgent/main/install.sh"
VERSION="1.0.0"

# ======================== 颜色 ========================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ======================== 工具函数 ========================
info()    { echo -e "${GREEN}[INFO]${NC} $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC} $*"; }
error()   { echo -e "${RED}[ERROR]${NC} $*"; }

check_root() {
    if [ "$(id -u)" -ne 0 ]; then
        error "请使用 root 权限运行: sudo openidcs $*"
        exit 1
    fi
}

check_installed() {
    if [ ! -d "${INSTALL_DIR}" ]; then
        error "OpenIDCS 未安装，请先运行安装脚本"
        echo -e "  ${CYAN}curl -fsSL ${INSTALL_SCRIPT_URL} | sudo bash${NC}"
        exit 1
    fi
}

# 获取安装类型
get_install_type() {
    if [ -f "${INSTALL_DIR}/.install_info" ]; then
        grep 'INSTALL_TYPE' "${INSTALL_DIR}/.install_info" 2>/dev/null | cut -d= -f2
    elif [ -f "${INSTALL_DIR}/OpenIDCS-Client" ]; then
        echo "binary"
    elif [ -f "${INSTALL_DIR}/MainServer.py" ]; then
        echo "source"
    else
        echo "unknown"
    fi
}

# 检查 systemd 是否可用
has_systemd() {
    command -v systemctl &>/dev/null && systemctl --version &>/dev/null 2>&1
}

# 检查服务是否已安装
service_installed() {
    [ -f "/etc/systemd/system/${SERVICE_NAME}.service" ]
}

# ======================== 命令实现 ========================

# --- 启动 ---
cmd_start() {
    check_root
    check_installed

    if has_systemd && service_installed; then
        info "通过 systemd 启动 OpenIDCS..."
        systemctl start "${SERVICE_NAME}"
        sleep 2
        if systemctl is-active --quiet "${SERVICE_NAME}"; then
            info "OpenIDCS 启动成功"
            echo -e "  访问地址: ${CYAN}http://$(hostname -I 2>/dev/null | awk '{print $1}' || echo 'localhost'):1880${NC}"
        else
            error "启动失败，请查看日志: openidcs log"
            exit 1
        fi
    else
        # 直接运行（无 systemd 环境）
        info "直接启动 OpenIDCS（后台运行）..."
        INSTALL_TYPE=$(get_install_type)
        cd "${INSTALL_DIR}" || exit 1

        if [ "${INSTALL_TYPE}" = "binary" ] && [ -f "${INSTALL_DIR}/OpenIDCS-Client" ]; then
            nohup "${INSTALL_DIR}/OpenIDCS-Client" > /var/log/openidcs/stdout.log 2>&1 &
        elif [ -f "${INSTALL_DIR}/venv/bin/python" ] && [ -f "${INSTALL_DIR}/MainServer.py" ]; then
            nohup "${INSTALL_DIR}/venv/bin/python" "${INSTALL_DIR}/MainServer.py" > /var/log/openidcs/stdout.log 2>&1 &
        elif [ -f "${INSTALL_DIR}/MainServer.py" ]; then
            nohup python3 "${INSTALL_DIR}/MainServer.py" > /var/log/openidcs/stdout.log 2>&1 &
        else
            error "找不到可执行文件"
            exit 1
        fi

        PID=$!
        echo "${PID}" > /var/run/openidcs.pid
        sleep 2

        if kill -0 "${PID}" 2>/dev/null; then
            info "OpenIDCS 启动成功 (PID: ${PID})"
            echo -e "  访问地址: ${CYAN}http://$(hostname -I 2>/dev/null | awk '{print $1}' || echo 'localhost'):1880${NC}"
        else
            error "启动失败，请查看日志: cat /var/log/openidcs/stdout.log"
            exit 1
        fi
    fi
}

# --- 停止 ---
cmd_stop() {
    check_root
    check_installed

    if has_systemd && service_installed; then
        info "停止 OpenIDCS..."
        systemctl stop "${SERVICE_NAME}"
        info "OpenIDCS 已停止"
    else
        # 通过 PID 文件停止
        if [ -f /var/run/openidcs.pid ]; then
            PID=$(cat /var/run/openidcs.pid)
            if kill -0 "${PID}" 2>/dev/null; then
                info "停止 OpenIDCS (PID: ${PID})..."
                kill "${PID}"
                sleep 2
                # 如果还没停，强制杀死
                if kill -0 "${PID}" 2>/dev/null; then
                    kill -9 "${PID}" 2>/dev/null
                fi
                rm -f /var/run/openidcs.pid
                info "OpenIDCS 已停止"
            else
                warn "进程不存在 (PID: ${PID})"
                rm -f /var/run/openidcs.pid
            fi
        else
            # 尝试查找进程
            PIDS=$(pgrep -f "OpenIDCS-Client|MainServer.py" 2>/dev/null || true)
            if [ -n "${PIDS}" ]; then
                info "停止 OpenIDCS 进程..."
                echo "${PIDS}" | xargs kill 2>/dev/null
                sleep 2
                echo "${PIDS}" | xargs kill -9 2>/dev/null 2>&1 || true
                info "OpenIDCS 已停止"
            else
                warn "OpenIDCS 未在运行"
            fi
        fi
    fi
}

# --- 重启 ---
cmd_restart() {
    check_root
    check_installed

    if has_systemd && service_installed; then
        info "重启 OpenIDCS..."
        systemctl restart "${SERVICE_NAME}"
        sleep 2
        if systemctl is-active --quiet "${SERVICE_NAME}"; then
            info "OpenIDCS 重启成功"
        else
            error "重启失败，请查看日志: openidcs log"
            exit 1
        fi
    else
        cmd_stop
        sleep 1
        cmd_start
    fi
}

# --- 状态 ---
cmd_status() {
    check_installed

    echo ""
    echo -e "${BOLD}═══════════════════════════════════════${NC}"
    echo -e "${BOLD} OpenIDCS-Client 状态信息${NC}"
    echo -e "${BOLD}═══════════════════════════════════════${NC}"

    # 安装信息
    if [ -f "${INSTALL_DIR}/.install_info" ]; then
        INSTALL_TYPE=$(grep 'INSTALL_TYPE' "${INSTALL_DIR}/.install_info" 2>/dev/null | cut -d= -f2)
        INSTALL_DATE=$(grep 'INSTALL_DATE' "${INSTALL_DIR}/.install_info" 2>/dev/null | cut -d= -f2-)
        INSTALL_VER=$(grep 'INSTALL_VERSION' "${INSTALL_DIR}/.install_info" 2>/dev/null | cut -d= -f2)
        echo -e " 安装类型:  ${CYAN}${INSTALL_TYPE:-unknown}${NC}"
        echo -e " 安装版本:  ${CYAN}${INSTALL_VER:-unknown}${NC}"
        echo -e " 安装时间:  ${CYAN}${INSTALL_DATE:-unknown}${NC}"
    fi
    echo -e " 安装目录:  ${CYAN}${INSTALL_DIR}${NC}"

    # 运行状态
    if has_systemd && service_installed; then
        STATUS=$(systemctl is-active "${SERVICE_NAME}" 2>/dev/null || echo "unknown")
        case "${STATUS}" in
            active)
                echo -e " 运行状态:  ${GREEN}● 运行中 (systemd)${NC}"
                ;;
            inactive)
                echo -e " 运行状态:  ${RED}● 已停止${NC}"
                ;;
            failed)
                echo -e " 运行状态:  ${RED}● 运行失败${NC}"
                ;;
            *)
                echo -e " 运行状态:  ${YELLOW}● ${STATUS}${NC}"
                ;;
        esac

        # systemd 详细信息
        MAIN_PID=$(systemctl show -p MainPID "${SERVICE_NAME}" 2>/dev/null | cut -d= -f2)
        if [ "${MAIN_PID}" != "0" ] && [ -n "${MAIN_PID}" ]; then
            echo -e " 进程 PID:  ${CYAN}${MAIN_PID}${NC}"
            # 内存使用
            MEM=$(ps -p "${MAIN_PID}" -o rss= 2>/dev/null | awk '{printf "%.1f MB", $1/1024}')
            [ -n "${MEM}" ] && echo -e " 内存使用:  ${CYAN}${MEM}${NC}"
        fi

        ENABLED=$(systemctl is-enabled "${SERVICE_NAME}" 2>/dev/null || echo "unknown")
        echo -e " 开机自启:  ${CYAN}${ENABLED}${NC}"
    else
        # 检查进程
        PIDS=$(pgrep -f "OpenIDCS-Client|MainServer.py" 2>/dev/null || true)
        if [ -n "${PIDS}" ]; then
            echo -e " 运行状态:  ${GREEN}● 运行中 (进程)${NC}"
            echo -e " 进程 PID:  ${CYAN}${PIDS}${NC}"
        else
            echo -e " 运行状态:  ${RED}● 未运行${NC}"
        fi
    fi

    # 端口占用
    if command -v ss &>/dev/null; then
        PORT_INFO=$(ss -tlnp 2>/dev/null | grep ':1880 ' || true)
    elif command -v netstat &>/dev/null; then
        PORT_INFO=$(netstat -tlnp 2>/dev/null | grep ':1880 ' || true)
    fi
    if [ -n "${PORT_INFO}" ]; then
        echo -e " 监听端口:  ${GREEN}1880 ✓${NC}"
    else
        echo -e " 监听端口:  ${YELLOW}1880 (未监听)${NC}"
    fi

    # 数据目录大小
    if [ -d "${DATA_DIR}" ]; then
        DATA_SIZE=$(du -sh "${DATA_DIR}" 2>/dev/null | awk '{print $1}')
        echo -e " 数据大小:  ${CYAN}${DATA_SIZE:-0}${NC}"
    fi

    echo -e "${BOLD}═══════════════════════════════════════${NC}"
    echo ""
}

# --- 更新 ---
cmd_update() {
    check_root
    check_installed

    info "开始更新 OpenIDCS..."

    INSTALL_TYPE=$(get_install_type)

    # 1. 停止服务
    RUNNING=false
    if has_systemd && service_installed; then
        if systemctl is-active --quiet "${SERVICE_NAME}"; then
            RUNNING=true
            info "停止当前服务..."
            systemctl stop "${SERVICE_NAME}"
        fi
    else
        PIDS=$(pgrep -f "OpenIDCS-Client|MainServer.py" 2>/dev/null || true)
        if [ -n "${PIDS}" ]; then
            RUNNING=true
            cmd_stop
        fi
    fi

    # 2. 备份数据
    if [ -d "${DATA_DIR}" ]; then
        BACKUP_NAME="${DATA_DIR}.bak.$(date +%Y%m%d%H%M%S)"
        info "备份数据到: ${BACKUP_NAME}"
        cp -r "${DATA_DIR}" "${BACKUP_NAME}"
    fi

    # 3. 下载新版本
    if [ "${INSTALL_TYPE}" = "binary" ]; then
        TMP_DIR=$(mktemp -d)
        trap "rm -rf ${TMP_DIR}" EXIT

        FILENAME=$(basename "${DOWNLOAD_URL}")
        info "下载新版本: ${FILENAME}"
        curl -fSL --progress-bar -o "${TMP_DIR}/${FILENAME}" "${DOWNLOAD_URL}" || die "下载失败"

        # 保留数据目录，清理旧程序文件
        info "更新程序文件..."
        # 保存数据和配置
        [ -d "${DATA_DIR}" ] && mv "${DATA_DIR}" "${TMP_DIR}/DataSaving_backup"
        [ -f "${INSTALL_DIR}/.install_info" ] && cp "${INSTALL_DIR}/.install_info" "${TMP_DIR}/.install_info_backup"

        # 清理安装目录（除了数据）
        rm -rf "${INSTALL_DIR:?}/"*

        # 解压新版本
        tar -xzf "${TMP_DIR}/${FILENAME}" -C "${INSTALL_DIR}" --strip-components=1 2>/dev/null \
            || tar -xzf "${TMP_DIR}/${FILENAME}" -C "${INSTALL_DIR}"

        # 恢复数据
        [ -d "${TMP_DIR}/DataSaving_backup" ] && mv "${TMP_DIR}/DataSaving_backup" "${DATA_DIR}"

        # 确保可执行权限
        find "${INSTALL_DIR}" -name "OpenIDCS-Client" -type f -exec chmod +x {} \;
    else
        # 源码更新
        TMP_DIR=$(mktemp -d)
        trap "rm -rf ${TMP_DIR}" EXIT

        if command -v git &>/dev/null && [ -d "${INSTALL_DIR}/.git" ]; then
            info "通过 Git 拉取更新..."
            cd "${INSTALL_DIR}" && git pull origin main
        else
            info "下载最新源码..."
            curl -fsSL "https://github.com/OpenIDCSTeam/HostAgent/archive/refs/heads/main.tar.gz" \
                -o "${TMP_DIR}/source.tar.gz" || die "源码下载失败"

            # 保存数据
            [ -d "${DATA_DIR}" ] && mv "${DATA_DIR}" "${TMP_DIR}/DataSaving_backup"
            [ -d "${INSTALL_DIR}/venv" ] && mv "${INSTALL_DIR}/venv" "${TMP_DIR}/venv_backup"

            # 解压
            rm -rf "${INSTALL_DIR:?}/"*
            tar -xzf "${TMP_DIR}/source.tar.gz" -C "${INSTALL_DIR}" --strip-components=1

            # 恢复
            [ -d "${TMP_DIR}/DataSaving_backup" ] && mv "${TMP_DIR}/DataSaving_backup" "${DATA_DIR}"
            [ -d "${TMP_DIR}/venv_backup" ] && mv "${TMP_DIR}/venv_backup" "${INSTALL_DIR}/venv"
        fi

        # 更新依赖
        if [ -f "${INSTALL_DIR}/venv/bin/pip" ] && [ -f "${INSTALL_DIR}/HostConfig/pipinstall.txt" ]; then
            info "更新 Python 依赖..."
            grep -v -E '^\s*#|^pythonnet|^pywin32|^cx-freeze|^nuitka|^hypy' \
                "${INSTALL_DIR}/HostConfig/pipinstall.txt" > "${TMP_DIR}/requirements-linux.txt"
            "${INSTALL_DIR}/venv/bin/pip" install -r "${TMP_DIR}/requirements-linux.txt" -q 2>/dev/null || true
        fi
    fi

    # 4. 更新安装信息
    sed -i "s/^INSTALL_DATE=.*/INSTALL_DATE=$(date '+%Y-%m-%d %H:%M:%S')/" "${INSTALL_DIR}/.install_info" 2>/dev/null || true

    # 5. 更新管理脚本
    if [ -f "${INSTALL_DIR}/bin/openidcs" ]; then
        cp "${INSTALL_DIR}/bin/openidcs" "${BIN_LINK}"
        chmod +x "${BIN_LINK}"
        info "管理脚本已更新"
    fi

    # 6. 重启服务
    if [ "${RUNNING}" = true ]; then
        info "重新启动服务..."
        cmd_start
    fi

    info "更新完成！"
}

# --- 卸载 ---
cmd_uninstall() {
    check_root
    check_installed

    echo ""
    echo -e "${RED}╔═══════════════════════════════════════════════╗${NC}"
    echo -e "${RED}║  ⚠️  警告：即将卸载 OpenIDCS-Client           ║${NC}"
    echo -e "${RED}╚═══════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "安装目录: ${CYAN}${INSTALL_DIR}${NC}"
    echo -e "数据目录: ${CYAN}${DATA_DIR}${NC}"
    echo ""

    read -p "确认卸载？(输入 yes 继续): " CONFIRM
    if [ "${CONFIRM}" != "yes" ]; then
        info "取消卸载"
        exit 0
    fi

    # 询问是否保留数据
    KEEP_DATA=false
    read -p "是否保留数据目录 (${DATA_DIR})？(y/n): " KEEP
    if [ "${KEEP}" = "y" ] || [ "${KEEP}" = "Y" ]; then
        KEEP_DATA=true
    fi

    # 1. 停止服务
    info "停止服务..."
    cmd_stop 2>/dev/null || true

    # 2. 移除 systemd 服务
    if has_systemd && service_installed; then
        info "移除 systemd 服务..."
        systemctl disable "${SERVICE_NAME}" 2>/dev/null || true
        rm -f "/etc/systemd/system/${SERVICE_NAME}.service"
        systemctl daemon-reload
    fi

    # 3. 备份数据（如果需要保留）
    if [ "${KEEP_DATA}" = true ] && [ -d "${DATA_DIR}" ]; then
        BACKUP_PATH="/root/openidcs-data-backup-$(date +%Y%m%d%H%M%S)"
        info "备份数据到: ${BACKUP_PATH}"
        cp -r "${DATA_DIR}" "${BACKUP_PATH}"
    fi

    # 4. 删除安装目录
    info "删除安装目录..."
    rm -rf "${INSTALL_DIR}"

    # 5. 删除管理脚本
    rm -f "${BIN_LINK}"

    # 6. 清理 PID 文件和日志
    rm -f /var/run/openidcs.pid

    echo ""
    info "OpenIDCS-Client 已卸载"
    if [ "${KEEP_DATA}" = true ]; then
        info "数据已备份到: ${BACKUP_PATH}"
    fi
    echo ""
}

# --- 日志 ---
cmd_log() {
    check_installed

    LINES="${1:-100}"

    if has_systemd && service_installed; then
        journalctl -u "${SERVICE_NAME}" -n "${LINES}" --no-pager -f
    else
        # 查看文件日志
        LOG_FILES=(
            "/var/log/openidcs/stdout.log"
            "${DATA_DIR}/log-kernel.log"
        )
        for LOG_F in "${LOG_FILES[@]}"; do
            if [ -f "${LOG_F}" ]; then
                info "日志文件: ${LOG_F}"
                tail -n "${LINES}" -f "${LOG_F}"
                exit 0
            fi
        done
        warn "未找到日志文件"
    fi
}

# --- 服务安装/管理 ---
cmd_service() {
    check_root
    check_installed

    ACTION="${1:-install}"
    case "${ACTION}" in
        install)
            if ! has_systemd; then
                error "系统不支持 systemd"
                exit 1
            fi

            INSTALL_TYPE=$(get_install_type)
            if [ "${INSTALL_TYPE}" = "binary" ]; then
                EXEC_START="${INSTALL_DIR}/OpenIDCS-Client"
            else
                EXEC_START="${INSTALL_DIR}/venv/bin/python ${INSTALL_DIR}/MainServer.py"
            fi

            cat > "/etc/systemd/system/${SERVICE_NAME}.service" << EOF
[Unit]
Description=OpenIDCS Client - IDC Virtualization Management Platform
Documentation=https://github.com/OpenIDCSTeam/HostAgent
After=network.target network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=${INSTALL_DIR}
ExecStart=${EXEC_START}
Restart=on-failure
RestartSec=10
StartLimitInterval=60
StartLimitBurst=3
Environment=PYTHONUNBUFFERED=1
Environment=LANG=en_US.UTF-8
StandardOutput=journal
StandardError=journal
SyslogIdentifier=openidcs
LimitNOFILE=65536
LimitNPROC=4096

[Install]
WantedBy=multi-user.target
EOF
            systemctl daemon-reload
            info "systemd 服务已安装"
            ;;
        remove)
            if service_installed; then
                systemctl stop "${SERVICE_NAME}" 2>/dev/null || true
                systemctl disable "${SERVICE_NAME}" 2>/dev/null || true
                rm -f "/etc/systemd/system/${SERVICE_NAME}.service"
                systemctl daemon-reload
                info "systemd 服务已移除"
            else
                warn "服务未安装"
            fi
            ;;
        enable)
            if service_installed; then
                systemctl enable "${SERVICE_NAME}"
                info "已设置开机自启"
            else
                error "服务未安装，请先运行: openidcs service install"
            fi
            ;;
        disable)
            if service_installed; then
                systemctl disable "${SERVICE_NAME}"
                info "已取消开机自启"
            else
                warn "服务未安装"
            fi
            ;;
        *)
            error "未知操作: ${ACTION}"
            echo "用法: openidcs service {install|remove|enable|disable}"
            ;;
    esac
}

# --- 信息 ---
cmd_info() {
    check_installed
    echo ""
    echo -e "${BOLD}OpenIDCS-Client 安装信息${NC}"
    echo "──────────────────────────────────────"
    if [ -f "${INSTALL_DIR}/.install_info" ]; then
        cat "${INSTALL_DIR}/.install_info" | while IFS='=' read -r KEY VAL; do
            printf "  %-18s %s\n" "${KEY}:" "${VAL}"
        done
    fi
    echo "──────────────────────────────────────"
    echo ""
}

# --- 帮助 ---
cmd_help() {
    echo ""
    echo -e "${BOLD}OpenIDCS-Client 管理工具 v${VERSION}${NC}"
    echo ""
    echo -e "${BOLD}用法:${NC}"
    echo "  openidcs <command> [options]"
    echo ""
    echo -e "${BOLD}命令:${NC}"
    echo -e "  ${GREEN}start${NC}                启动 OpenIDCS 服务"
    echo -e "  ${GREEN}stop${NC}                 停止 OpenIDCS 服务"
    echo -e "  ${GREEN}restart${NC}              重启 OpenIDCS 服务"
    echo -e "  ${GREEN}status${NC}               查看运行状态"
    echo -e "  ${GREEN}update${NC}               更新到最新版本"
    echo -e "  ${GREEN}uninstall${NC}            卸载 OpenIDCS"
    echo -e "  ${GREEN}log${NC} [lines]          查看实时日志 (默认100行)"
    echo -e "  ${GREEN}info${NC}                 查看安装信息"
    echo -e "  ${GREEN}service${NC} <action>     systemd 服务管理"
    echo -e "  ${GREEN}help${NC}                 显示此帮助信息"
    echo ""
    echo -e "${BOLD}服务管理 (openidcs service):${NC}"
    echo -e "  ${CYAN}install${NC}              安装 systemd 服务"
    echo -e "  ${CYAN}remove${NC}               移除 systemd 服务"
    echo -e "  ${CYAN}enable${NC}               设置开机自启"
    echo -e "  ${CYAN}disable${NC}              取消开机自启"
    echo ""
    echo -e "${BOLD}示例:${NC}"
    echo "  sudo openidcs start             # 启动服务"
    echo "  sudo openidcs status            # 查看状态"
    echo "  sudo openidcs update            # 更新版本"
    echo "  sudo openidcs service enable    # 设置开机自启"
    echo "  sudo openidcs log 200           # 查看最近200行日志"
    echo ""
    echo -e "${BOLD}一键安装:${NC}"
    echo -e "  curl -fsSL ${INSTALL_SCRIPT_URL} | sudo bash"
    echo ""
}

# ======================== 主入口 ========================
case "${1}" in
    start)
        cmd_start
        ;;
    stop)
        cmd_stop
        ;;
    restart)
        cmd_restart
        ;;
    status)
        cmd_status
        ;;
    update|upgrade)
        cmd_update
        ;;
    uninstall|remove)
        cmd_uninstall
        ;;
    log|logs)
        cmd_log "${2}"
        ;;
    service|svc)
        cmd_service "${2}"
        ;;
    info)
        cmd_info
        ;;
    help|--help|-h)
        cmd_help
        ;;
    version|--version|-v)
        echo "openidcs v${VERSION}"
        ;;
    "")
        cmd_help
        ;;
    *)
        error "未知命令: ${1}"
        echo ""
        cmd_help
        exit 1
        ;;
esac
